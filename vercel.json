{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "excludeFiles": [
                    "node_modules/**",
                    "public/media/**",
                    "public/uploads/**",
                    "tests/**",
                    "storage/framework/cache/**"
                ]
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}